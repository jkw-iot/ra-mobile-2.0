# ══════════════════════════════════════════════════════════════
# RoomAlyzer Mobile — environment variables
#
# Copy this file to `.env` and fill in the values. Expo inlines
# all EXPO_PUBLIC_* vars at build time. NEVER put secrets in this
# file — only public keys (the Firebase web keys are public).
# ══════════════════════════════════════════════════════════════

# Hono API base URL. Leave unset for production default.
# Examples:
#   http://localhost:3001  (web repo dev server)
#   https://v2.roomalyzer.com
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001

# Firebase web SDK configuration (same project as the web app).
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=

# Google OAuth 2.0 client IDs (from Google Cloud Console) —
# required for "Sign in with Google" on mobile. Leave empty to
# hide the Google button.
EXPO_PUBLIC_GOOGLE_OAUTH_IOS=
EXPO_PUBLIC_GOOGLE_OAUTH_ANDROID=
EXPO_PUBLIC_GOOGLE_OAUTH_WEB=

# Optional: Sentry DSN (leave empty to disable).
EXPO_PUBLIC_SENTRY_DSN=
