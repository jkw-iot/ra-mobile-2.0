{
  "name": "roomalyzer-mobile",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start --dev-client",
    "start:go": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "check:secrets": "node scripts/check-no-secrets.mjs",
    "prepare": "husky",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\" \"app/**/*.{ts,tsx}\"",
    "gen:api": "node scripts/gen-api.mjs https://v2.roomalyzer.com/api/docs/openapi.json",
    "gen:api:local": "node scripts/gen-api.mjs http://localhost:3001/api/docs/openapi.json",
    "net:home": "node scripts/set-network.mjs home",
    "net:work": "node scripts/set-network.mjs work",
    "net:auto": "node scripts/set-network.mjs auto",
    "net:list": "node scripts/set-network.mjs list"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@tanstack/query-async-storage-persister": "^5.100.1",
    "@tanstack/react-query": "^5.100.1",
    "@tanstack/react-query-persist-client": "^5.100.1",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.17",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-localization": "~17.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sensors": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.12.1",
    "i18next": "^26.0.7",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-i18next": "^17.0.4",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "eas-cli": "^18.10.0",
    "husky": "^9.1.7",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "react-native-svg-transformer": "^1.5.3",
    "typescript": "~5.9.2"
  }
